{
  "name": "mitsubachi-flower-harness",
  "version": "0.1.0",
  "private": true,
  "description": "After Effects CEP development harness for Mitsubachi flower.",
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node --test build/tests/*.test.js",
    "lint": "npm run build && node scripts/lint-built.mjs",
    "doctor": "node scripts/doctor.mjs",
    "install:dev": "node scripts/install-dev-extension.mjs",
    "uninstall:dev": "node scripts/uninstall-dev-extension.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
